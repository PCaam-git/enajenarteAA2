        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200 OK o 204 No Content\", function () {\r",
              "    pm.expect([200, 204]).to.include(pm.response.code);\r",
              "});\r",
              "\r",
              "if (pm.response.code === 200) {\r",
              "    pm.test(\"La respuesta es una lista y contiene campos v2\", function () {\r",
              "        const json = pm.response.json();\r",
              "        pm.expect(json).to.be.an(\"array\");\r",
              "\r",
              "        const workshop = json.find(item => item.id === Number(pm.collectionVariables.get(\"workshopAId\")));\r",
              "        pm.expect(workshop).to.not.be.undefined;\r",
              "        pm.expect(workshop).to.have.property(\"maxCapacity\");\r",
              "        pm.expect(workshop).to.have.property(\"speakerName\");\r",
              "    });\r",
              "}"
